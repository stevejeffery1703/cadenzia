# Copy to .env for local dev. NEVER commit real secrets.
# In production these are set via `wrangler secret put NAME` (Worker)
# and Vite build-time vars (VITE_*) for the frontend.

# --- Frontend (exposed to the browser, must be public-safe) ---
VITE_APP_NAME=Cadenzia
VITE_APP_URL=http://localhost:5173

# --- Worker secrets (server-side only) ---
# Note: the database is Cloudflare D1, bound as `DB` in wrangler.jsonc — no
# URL/key pair needed, unlike the old Supabase setup.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# Set to "true" ONLY after activating Managed Payments in the Stripe Dashboard,
# passing the eligibility review, and setting a Managed-Payments-eligible tax code
# on the product (txcd_10401200). Unset / anything-else = merchant of record OFF
# (Stripe stays a plain processor). Verify in test mode before enabling live.
STRIPE_MANAGED_PAYMENTS=
RESEND_API_KEY=
APP_URL=http://localhost:5173
JWT_SECRET=

# --- Deploy (GitHub Actions) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
